# Copy to .env and fill in real values. Never commit .env.

# dev | prod — dev renders key-value logs to the console, prod renders JSON.
ENVIRONMENT=dev

# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# SQLAlchemy database URL. SQLite for the MVP; PostgreSQL later
# (e.g. postgresql+psycopg://user:pass@host:5432/real_estate).
DATABASE_URL=sqlite:///./real_estate.db

# Telegram Bot API token (from @BotFather). Required to send notifications.
TELEGRAM_BOT_TOKEN=

# Fernet key (44 url-safe base64 chars) encrypting notification_channel secrets at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
NOTIFICATION_ENCRYPTION_KEY=

# The single MVP user's email — get-or-created at startup (no auth system yet, V3 scope).
OWNER_EMAIL=owner@example.test

# Scheduler cadence (seconds). Planner jitter avoids thundering-herd on round ticks (doc06 §5).
PLANNER_INTERVAL_SECONDS=60
PLANNER_JITTER_SECONDS=10
DISPATCHER_INTERVAL_SECONDS=30
